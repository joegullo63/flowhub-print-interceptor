<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup useLegacyV2RuntimeActivationPolicy="true">
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <appSettings>
    <!-- This must exactly match the Windows printer queue selected in Flowhub Maui. -->
    <add key="PrinterName" value="CONFIGURED_BY_INSTALLER" />

    <!-- Fail-safe: a prompt that is not answered keeps the drawer locked. -->
    <add key="PromptTimeoutSeconds" value="30" />

    <!-- Star's normal primary-drawer timing is 200 ms on, 200 ms off. -->
    <add key="PulseOnMilliseconds" value="200" />
    <add key="PulseOffMilliseconds" value="200" />

    <!-- Flowhub writes each source PDF here before sending it to the Windows queue. -->
    <add key="FlowhubPrintDirectory" value="%APPDATA%\FlowhubMaui\print-util\printFiles" />
    <add key="ReceiptHeader" value="CHANGE_ME_TRANSACTION_HEADER" />
    <add key="FulfillmentHeader" value="In-Store-Fulfillment" />
    <add key="ClassificationWindowSeconds" value="120" />
    <add key="ReleaseRepository" value="joegullo63/flowhub-print-interceptor" />
    <add key="UpdateCheckHours" value="6" />
    <add key="StartWithWindows" value="True" />
    <add key="DesktopShortcut" value="True" />
  </appSettings>
</configuration>
